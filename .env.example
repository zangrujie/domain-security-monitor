# Example environment configuration for Domain Security Monitor

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domain_security
DB_USER=postgres
DB_PASSWORD=your_password_here

# Flask
FLASK_SECRET_KEY=change_me_to_a_secure_value

# Optional: API keys
VT_API_KEY=
URLHAUS_API_KEY=

# Optional directories
SCREENSHOT_DIR=monitoring_results/screenshots

# Redis (if used)
REDIS_URL=redis://localhost:6379/0
