# PostgreSQL database connection configuration

DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domain_security

# Threat intelligence API keys
# Register at https://www.virustotal.com/ to get an API key
VT_API_KEY=your_virustotal_api_key_here

# URLHaus does not require an API key for public access
# URLHAUS_API_KEY=not_required

# Optional: AbuseIPDB API key
# ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Application settings
DEBUG=False
SECRET_KEY=change_this_to_a_random_secret_key
LOG_LEVEL=INFO

# Rate limiting settings
VT_RATE_LIMIT_REQUESTS=4
VT_RATE_LIMIT_PERIOD=60  # seconds

# DNS scanning settings
DNS_SCAN_RATE=500  # queries per second
DNS_RETRY_COUNT=2

# Web server settings
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_DEBUG=False

# Database connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600